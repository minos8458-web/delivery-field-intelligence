#!/bin/sh
# Gradle start script (Unix)
# Generated for DFI C4 spike — Gradle 8.9

##############################################################################
# Gradle start-up environment
##############################################################################

APP_NAME="Gradle"
APP_BASE_NAME=`basename "$0"`
APP_HOME=`cd "$(dirname "$0")" && pwd`

# Default JVM options
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Use JAVA_HOME if set, otherwise fall back to PATH
if [ -n "$JAVA_HOME" ]; then
    JAVA_EXE="$JAVA_HOME/bin/java"
else
    JAVA_EXE="java"
fi

# Determine wrapper JAR
WRAPPER_JAR="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
WRAPPER_LAUNCHER="org.gradle.wrapper.GradleWrapperMain"

exec "$JAVA_EXE" $DEFAULT_JVM_OPTS $JAVA_OPTS -classpath "$WRAPPER_JAR" \
     $WRAPPER_LAUNCHER "$@"
